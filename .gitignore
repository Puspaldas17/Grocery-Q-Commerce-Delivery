# ──────────────────────────────────────────
# GigShield AI — .gitignore
# ──────────────────────────────────────────

# ── Environment Variables (NEVER commit these) ──
.env
.env.local
.env.development
.env.production
backend/.env
frontend/.env
ai_service/.env

# ── Node.js ────────────────────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Vite / Frontend Build ───────────────────────
frontend/dist/
frontend/.vite/

# ── Python / AI Service ─────────────────────────
ai_service/__pycache__/
ai_service/*.pyc
ai_service/*.pyo
ai_service/.venv/
ai_service/venv/
*.egg-info/
dist/
build/

# ── OS & Editor ─────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
